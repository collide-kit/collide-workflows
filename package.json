{
  "name": "@collide-kit/collide-workflows",
  "version": "1.1.0",
  "description": "Reusable GitHub Actions composite actions for CollideKit projects.",
  "keywords": [
    "@collide-kit:github-actions",
    "@collide-kit:workflows",
    "@collide-kit:ci-cd",
    "@collide-kit:composite-actions"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/collide-kit/collide-workflows"
  },
  "license": "MIT",
  "author": {
    "name": "gratisv",
    "email": "gratis.v@proton.me",
    "url": "https://github.com/gratisv"
  },
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "fmt:check": "prettier -c .",
    "fmt:check:cache": "prettier -c . --cache",
    "fmt:fix": "prettier -w . --log-level=warn",
    "fmt:fix:cache": "prettier -w . --cache --log-level=warn",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.8.1",
    "prettier-plugin-multiline-arrays": "^4.1.3",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0",
  "publishConfig": {
    "access": "public"
  }
}
