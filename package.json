{
  "name": "collide-workflows",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "fmt:check": "prettier -c .",
    "fmt:check:cache": "prettier -c . --cache",
    "fmt:fix": "prettier -w . --log-level=warn",
    "fmt:fix:cache": "prettier -w . --cache --log-level=warn",
    "release": "changeset publish",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.8.1",
    "prettier-plugin-multiline-arrays": "^4.1.3",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0",
  "publishConfig": {
    "access": "public"
  }
}
